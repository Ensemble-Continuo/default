<!DOCTYPE html>
<html>

<head>
  <title>{{ title }}</title>
  <meta charset="utf-8" />
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
  <link rel="stylesheet" type="text/css" href="/styles/navbar.css">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
  <!-- Global site tag (gtag.js) - Google Ads: 593551022 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-593551022"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
                                                    function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'AW-593551022');

</script>
<link rel="stylesheet" type="text/css" href="/styles/main.css">
<link rel="shortcut icon" type="image/jpg" href="images/ec_header_logo.png">
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-SLMVDHBTBP"></script>
<script>
  window.dataLayer = window.dataLayer || [];
                                                    function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-SLMVDHBTBP');
    </script>
    {% block headTags %}
    {% endblock %}
</head>

<body onload="document.body.style.opacity='1'">
  <div id="rnb">
    <div class="navcontainer">
      <div class="home" id="header_logo">
        <a href="/"><img src="/images/ec_header_logo.png" /></a>
      </div>
      <input type="checkbox" id="menu-toggle" class="menu-checkbox" aria-label="Toggle Navigation">
      <label for="menu-toggle" class="hamburger">&#9776;</label>
      <nav class="stroke">
        <div class="pages">
          <ul>
            <li>
              <h3><a href="/pages/performances.html">Performances</a></h3>
            </li>
            <li>
              <h3><a href="/pages/donate.html">Donate</a></h3>
              </li>
              <li>
              <h3><a href="/pages/join_us.html">Join us</a></h3>
            </li>
            <li>
              <h3><a href="/pages/contact_us.html">Contact us</a></h3>
            </li>
            <li>
              <h3><a href="/pages/members.html">Members</a></h3>
            </li>
            <li>
              <h3><a href="/pages/about_us.html">About us</a></h3>
            </li>
            <li>
              <h3><a href="/pages/faqs.html">FAQs</a></h3>
            </li>
          </ul>
        </div>
      </nav>
    </div>
  </div>
  {% block content %}
  {% if noWrapper %}
  {{ content | safe }}
  {% else %}
  <div id="maintext" class="container">
    {{ content | safe }}
  </div>
  {% endif %}
  {% endblock %}
  </body>

</html>